{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/research_guard.py\" --event SessionStart",
            "commandWindows": "powershell -NoProfile -Command \"$r=(git rev-parse --show-toplevel); python (Join-Path $r '.codex/hooks/research_guard.py') --event SessionStart\"",
            "timeout": 2,
            "statusMessage": "Loading research integrity baseline"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Bash|shell_command|apply_patch|Edit|Write|mcp__.*create_pull_request.*)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/research_guard.py\" --event PreToolUse",
            "commandWindows": "powershell -NoProfile -Command \"$r=(git rev-parse --show-toplevel); python (Join-Path $r '.codex/hooks/research_guard.py') --event PreToolUse\"",
            "timeout": 35,
            "statusMessage": "Checking research mutation policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Bash|shell_command|apply_patch|Edit|Write|mcp__.*)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/research_guard.py\" --event PostToolUse",
            "commandWindows": "powershell -NoProfile -Command \"$r=(git rev-parse --show-toplevel); python (Join-Path $r '.codex/hooks/research_guard.py') --event PostToolUse\"",
            "timeout": 35,
            "statusMessage": "Recording research evidence"
          }
        ]
      }
    ],
    "SubagentStart": [],
    "SubagentStop": [],
    "Stop": []
  }
}
