{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/research_guard.py\" --event SessionStart",
            "commandWindows": "powershell -NoProfile -Command \"$r=(git rev-parse --show-toplevel); python (Join-Path $r '.codex/hooks/research_guard.py') --event SessionStart\"",
            "timeout": 5,
            "statusMessage": "Loading research integrity baseline"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write|mcp__.*create_pull_request.*)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/research_guard.py\" --event PreToolUse",
            "commandWindows": "powershell -NoProfile -Command \"$r=(git rev-parse --show-toplevel); python (Join-Path $r '.codex/hooks/research_guard.py') --event PreToolUse\"",
            "timeout": 35,
            "statusMessage": "Checking research mutation policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write|mcp__.*)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/research_guard.py\" --event PostToolUse",
            "commandWindows": "powershell -NoProfile -Command \"$r=(git rev-parse --show-toplevel); python (Join-Path $r '.codex/hooks/research_guard.py') --event PostToolUse\"",
            "timeout": 35,
            "statusMessage": "Recording research evidence"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/research_guard.py\" --event SubagentStart",
            "commandWindows": "powershell -NoProfile -Command \"$r=(git rev-parse --show-toplevel); python (Join-Path $r '.codex/hooks/research_guard.py') --event SubagentStart\"",
            "timeout": 5,
            "statusMessage": "Loading specialist contract"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/research_guard.py\" --event SubagentStop",
            "commandWindows": "powershell -NoProfile -Command \"$r=(git rev-parse --show-toplevel); python (Join-Path $r '.codex/hooks/research_guard.py') --event SubagentStop\"",
            "timeout": 5,
            "statusMessage": "Validating specialist verdict"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/research_guard.py\" --event Stop",
            "commandWindows": "powershell -NoProfile -Command \"$r=(git rev-parse --show-toplevel); python (Join-Path $r '.codex/hooks/research_guard.py') --event Stop\"",
            "timeout": 7200,
            "statusMessage": "Closing research integrity gates"
          }
        ]
      }
    ]
  }
}
