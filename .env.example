# =============================================================================
# OKX TRADING BOT — CONFIGURACIÓN DE ENTORNO
# Copia este archivo a .env y rellena tus valores reales.
# NUNCA subas .env a git. Ya está en .gitignore.
# =============================================================================

# --- Credenciales OKX ---
# Cómo obtenerlas: https://www.okx.com/es/help/how-to-create-api-keys
# Obligatorias en modo live, pueden dejarse vacías en modo paper.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# --- Modo de operación ---
# "paper" → simulación local, sin órdenes reales. Arranque por defecto.
# "live"  → órdenes reales en OKX. Requiere credenciales válidas.
TRADING_MODE=paper

# Si usas la cuenta de demo/sandbox de OKX, ponlo en true.
# En producción real debe ser false.
OKX_SANDBOX=true

# --- Pares a operar ---
# Lista separada por comas. Deben existir en OKX spot.
TRADING_PAIRS=BTC-USDT,ETH-USDT,SOL-USDT

# --- Gestión de riesgo ---
# % máximo del portfolio total que puede estar en riesgo en una sola operación.
MAX_PORTFOLIO_RISK_PCT=2.0

# Número máximo de posiciones abiertas simultáneas.
MAX_OPEN_POSITIONS=10

# Si el bot pierde este % del portfolio en un día, para automáticamente.
DAILY_LOSS_LIMIT_PCT=5.0

# --- Configuración fiscal ---
# Año fiscal para el informe IRPF.
FISCAL_YEAR=2025

# Método de coste. En España la AEAT exige FIFO para criptomonedas.
COST_BASIS_METHOD=FIFO

# --- Señales externas (copytrading) ---
# "none"               → sin señales externas (solo bots propios)
# "tradingview_webhook" → recibe alertas de TradingView por webhook HTTP
# "telegram"           → lee señales de un canal de Telegram
SIGNAL_SOURCE=none

# Puerto donde escucha el servidor de webhooks (solo si SIGNAL_SOURCE=tradingview_webhook)
WEBHOOK_PORT=8080

# Token del bot de Telegram y canal (solo si SIGNAL_SOURCE=telegram)
# Obtén el token en @BotFather y el channel_id con @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# --- Control remoto por Telegram (tools/telegram_remote.py) ---
# TELEGRAM_BOT_TOKEN de arriba se reutiliza. TELEGRAM_CHAT_ID = TU chat privado con el
# bot (no un canal): habla con @userinfobot para obtenerlo. Solo ese chat puede dar ordenes.
TELEGRAM_CHAT_ID=

# NOTA para paper trading en VPS: OKX_SANDBOX=false para que los datos de mercado
# sean del exchange REAL (el sandbox es un entorno demo con precios propios; romperia
# la paridad con el backtest). Paper + sandbox=false NO envia ordenes reales nunca.

# --- Demo trading OKX (solo bots con execution=okx_demo, ver tools/okx_demo_setup.py) ---
# API key DISTINTA de la real: se crea DENTRO del modo demo trading de OKX
# (perfil -> Demo trading -> API). Las ordenes van a la cuenta demo (fondos simulados);
# los datos de mercado del bot siguen siendo los reales (no rompe paridad F15).
# NOTA 2026-07-11: el feed de PRECIOS demo esta medido con high/low inflados $80-250/vela;
# por eso el cliente demo solo usa flag=1 para ordenes/balance, nunca para market data.
OKX_DEMO_API_KEY=
OKX_DEMO_SECRET_KEY=
OKX_DEMO_PASSPHRASE=
# Dominio API de la cuenta demo. Cuentas de la entidad europea (MiCA, my.okx.com):
# poner https://my.okx.com — sus keys devuelven error 60032 contra www.okx.com.
# Cuentas globales: dejar el default https://www.okx.com (o vacio).
OKX_DEMO_DOMAIN=https://www.okx.com
