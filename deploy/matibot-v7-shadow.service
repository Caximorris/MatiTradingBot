[Unit]
Description=MatiTradingBot v7 Cycle Core shadow (paper-only)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__RUN_USER__
WorkingDirectory=__APP_DIR__
Environment=PYTHONUNBUFFERED=1
ExecStart=__APP_DIR__/.venv/bin/python main.py start --only swing_cycle_core_v7_btc_usdt_shadow --tick 30
Restart=on-failure
RestartSec=10
NoNewPrivileges=true
PrivateTmp=true
MemoryMax=350M

[Install]
WantedBy=multi-user.target
