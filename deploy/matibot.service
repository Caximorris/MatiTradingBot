# Plantilla systemd — bot de trading (paper). install_vm.sh sustituye __APP_DIR__ y __RUN_USER__.
[Unit]
Description=MatiTradingBot - Swing Allocator (paper)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__RUN_USER__
WorkingDirectory=__APP_DIR__
ExecStart=__APP_DIR__/.venv/bin/python main.py start
Restart=always
RestartSec=15
# El bot persiste estado (BotState + data/runtime/) — un restart no pierde nada.

[Install]
WantedBy=multi-user.target
